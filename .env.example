# Remote Supabase Postgres (Project Settings → Database → Connection string URI)
# Use the "Transaction" pooler URL for serverless/Next.js deploys when available.
# Powerful role (BYPASSRLS) — migrations, seed, and admin/bootstrap scripts ONLY.
# Never use this for request-serving reads; see RUNTIME_DATABASE_URL below.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Least-privilege role (NOBYPASSRLS) created by migration 0003_auth_flow.sql.
# All report-data reads at runtime go through this connection so Row Level
# Security policies on metric_values/statement_lines/operating_kpis actually
# apply (defense-in-depth alongside the application-layer audience filter).
RUNTIME_DATABASE_URL=postgresql://app_runtime:YOUR_APP_RUNTIME_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Supabase Auth / client (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (never expose to the browser) — required for invites and admin
# role management (auth.admin.inviteUserByEmail, profile audience/is_admin writes)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic Claude — PDF structured extraction (admin ingest). Never commit a real key.
CLAUDE_API_KEY=sk-ant-api03-...
# Required — Claude model id for extraction + commentary
AI_MODEL=claude-haiku-4-5

# Used to build invite and password-reset email redirect links (Server Actions
# have no Host header). Required in production — without it, emails would
# point at localhost. Example for this deploy:
# NEXT_PUBLIC_SITE_URL=https://senus-plc-dashboard.vercel.app
# NEXT_PUBLIC_SITE_URL=https://senus-board.example.com

# Comma-separated list of extra origins Server Actions may be invoked from
# (next.config.ts). Set to your real deploy domain once known; leave unset
# for same-origin-only (Next's default), which is correct for local dev.
# SERVER_ACTIONS_ALLOWED_ORIGINS=senus-plc-dashboard.vercel.app

# Playwright E2E (optional — npm run test:e2e)
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=your-password
# CREDIT_EMAIL=credit@example.com
# CREDIT_PASSWORD=your-password
# INVESTOR_EMAIL=investor@example.com
# INVESTOR_PASSWORD=your-password
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
